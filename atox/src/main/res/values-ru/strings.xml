    <!-- Welcome Screen -->
    <string name="welcome_intro_title">Добро пожаловать в aTox</string>
    <string name="welcome_intro_description">aTox — это бесплатный мессенджер с открытым исходным кодом, использующий протокол Tox. Безопасное общение без посредников и слежки.</string>
